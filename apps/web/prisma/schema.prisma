generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  firstName     String?  @map("first_name")
  lastName      String?  @map("last_name")
  name          String?
  company       String?
  phone         String?
  role          String?  // admin, sales_rep, manager, support
  avatar        String?
  password      String?  // hashed, for credentials auth
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  ownedWorkspaces   Workspace[]
  workspaceMembers  WorkspaceMember[]
  assignedTasks     Task[]          @relation("TaskAssignee")
  createdNotes      Note[]          @relation("NoteAuthor")
  createdTimelineEvents TimelineEvent[]

  @@map("users")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("starter") // starter, pro, enterprise
  ownerId     String   @map("owner_id")
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members     WorkspaceMember[]
  accounts    Account[]
  contacts    Contact[]
  deals       Deal[]
  tasks       Task[]
  notes       Note[]
  timelineEvents TimelineEvent[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("member") // owner, admin, member
  joinedAt    DateTime @default(now()) @map("joined_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Account {
  id                String   @id @default(cuid())
  workspaceId       String   @map("workspace_id")
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  domain            String?
  industry          String?
  size              String?  // 1-10, 11-50, 51-200, 201-500, 500+
  website           String?
  phone             String?
  billingAddress    Json?    @map("billing_address")
  shippingAddress   Json?    @map("shipping_address")
  customFields      Json?    @map("custom_fields")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  contacts    Contact[]
  deals       Deal[]
  timelineEvents TimelineEvent[]

  @@index([workspaceId])
  @@map("accounts")
}

model Contact {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId   String?  @map("account_id")
  account     Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  email       String?
  phone       String?
  title       String?
  department  String?
  linkedin    String?
  avatar      String?
  isPrimary   Boolean  @default(false) @map("is_primary")
  customFields Json?   @map("custom_fields")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  deals       Deal[]
  notes       Note[]
  timelineEvents TimelineEvent[]

  @@index([workspaceId])
  @@index([accountId])
  @@map("contacts")
}

enum DealStage {
  lead
  qualify
  propose
  negotiate
  won
  lost
}

model Deal {
  id            String    @id @default(cuid())
  workspaceId   String    @map("workspace_id")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId     String?   @map("account_id")
  account       Account?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contactId     String?   @map("contact_id")
  contact       Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  name          String
  stage         DealStage @default(lead)
  value         Decimal   @default(0) @db.Decimal(15, 2)
  currency      String    @default("USD")
  probability   Int       @default(0)
  closeDate     DateTime? @map("close_date")
  description   String?
  customFields  Json?     @map("custom_fields")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  timelineEvents TimelineEvent[]

  @@index([workspaceId])
  @@index([accountId])
  @@index([stage])
  @@map("deals")
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assigneeId  String?   @map("assignee_id")
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  accountId   String?   @map("account_id")
  contactId   String?   @map("contact_id")
  dealId      String?   @map("deal_id")
  title       String
  description String?
  status      TaskStatus @default(todo)
  priority    TaskPriority @default(medium)
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@index([assigneeId])
  @@index([status])
  @@map("tasks")
}

enum NoteType {
  manual
  meeting
  call
  email
  document
  voice_memo
}

model Note {
  id              String    @id @default(cuid())
  workspaceId     String    @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  authorId        String    @map("author_id")
  author          User      @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  contactId       String?   @map("contact_id")
  contact         Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId          String?   @map("deal_id")
  title           String
  content         String    @db.Text
  type            NoteType  @default(manual)
  aiSummary       String?   @map("ai_summary")
  sentiment       String?   // positive, neutral, negative
  actionsExtracted Json?    @map("actions_extracted")
  tags            String[]  @default([])
  isShared        Boolean   @default(false) @map("is_shared")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@index([contactId])
  @@index([authorId])
  @@map("notes")
}

enum TimelineEventType {
  call
  email
  meeting
  note
  deal_stage_change
  task_completed
}

model TimelineEvent {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId   String?   @map("account_id")
  account     Account?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contactId   String?   @map("contact_id")
  contact     Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId      String?   @map("deal_id")
  deal        Deal?      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  authorId    String?   @map("author_id")
  author      User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  type        TimelineEventType
  title       String
  description String?
  metadata    Json?
  occurredAt  DateTime  @default(now()) @map("occurred_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([contactId])
  @@index([accountId])
  @@index([dealId])
  @@index([occurredAt])
  @@map("timeline_events")
}
